# ============================================================
# nec_ll — Client Configuration
# Copy to config/client.env and edit before running setup.sh
# ============================================================

# HuggingFace model identifier (used by download_model.py)
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct

# HuggingFace token — NOT required (Qwen3.5-27B is public)
HF_TOKEN=

# Local path where the model will be downloaded
LLM_DOWNLOAD_PATH=/home/models/Qwen3.5-27B

# Final model name and path after rename (used by vLLM)
LLM_MODEL_NAME=Q3_LLM_V2
LLM_MODEL_PATH=/home/models/Q3_LLM_V2

# vLLM server port
LLM_PORT=8004

# GPU memory utilisation (0.72 is safe for H100 80GB with Qwen3.5-27B)
LLM_GPU_MEM=0.72

# Max context length
LLM_MAX_LEN=32768

# CUDA device index (0 for single H100)
LLM_CUDA_DEVICE=0
