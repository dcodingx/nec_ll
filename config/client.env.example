# ============================================================
# shisa-llm-deploy — Client Configuration
# Copy to config/client.env and edit before running setup.sh
# ============================================================

# HuggingFace model identifier (used by download_model.py)
HF_MODEL_ID=shisa-ai/LLM_Q3_V1

# HuggingFace token — NOT required for LLM_Q3_V1 (public model).
# Leave this blank. Only needed if you switch to a private/gated model.
HF_TOKEN=

# Local path where the model will be saved (download target & vLLM model path)
LLM_MODEL_PATH=/opt/voicebot/models/LLM_Q3_V1

# Model name served by vLLM (must match the name the wrapper queries)
LLM_MODEL_NAME=LLM_Q3_V1

# vLLM server port
LLM_PORT=8004

# GPU memory utilisation (0.90 is safe for H100 80GB)
LLM_GPU_MEM=0.90

# CUDA device index (0 for single H100)
LLM_CUDA_DEVICE=0

# API wrapper port
LLM_API_PORT=8005

# URL the wrapper uses to reach vLLM
LLM_VLLM_BASE_URL=http://localhost:8004/v1

# Test client base URL (points at the wrapper)
LLM_API_BASE_URL=http://localhost:8005
